{
  "name": "cloud-agent",
  "version": "1.0.0",
  "schema_version": "0.7.0",
  "description": "Universal cloud observability, control-plane execution, and anomaly detection agent supporting any cloud provider via pluggable adapters.",
  "skills": [
    {"name": "cloud.monitoring.metrics"},
    {"name": "cloud.monitoring.health_check"},
    {"name": "cloud.execute.action"},
    {"name": "cloud.discover.resources"},
    {"name": "cloud.diagnose.anomaly"},
    {"name": "cloud.list.resources"}
  ],
  "domains": ["cloud-infrastructure", "observability", "control-plane"],
  "locators": [
    {"type": "openapi", "url": "http://cloud-agent:8005/openapi.json"}
  ],
  "modules": {
    "protocols": ["rest", "mock", "mock_cloud", "aws", "gcp", "coms"],
    "resource_types": ["vm", "container", "function", "storage_bucket", "network_interface", "cluster_node"]
  }
}
