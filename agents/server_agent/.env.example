# Required External Services
CAPABILITY_REGISTRY_URL=http://localhost:8020
CRED_VAULT_URL=http://localhost:8200
SERVICE_TOKEN=mock-service-token
CMDB_URL=http://localhost:8004

# Polling Config
POLL_ENABLED=true
POLL_INTERVAL_SECONDS=120
POLL_SERVER_LIST_SOURCE=cmdb

# Anomaly thresholds (all have defaults, all overridable)
CPU_WARNING_THRESHOLD=80.0
MEMORY_WARNING_THRESHOLD=85.0
TEMPERATURE_WARNING_THRESHOLD=75.0
TEMPERATURE_CRITICAL_THRESHOLD=90.0
FAN_FAILURE_STATUS_VALUES=Failed,CriticalFailure,Critical
PSU_FAILURE_STATUS_VALUES=Failed,CriticalFailure,Critical
DISK_PREDICTIVE_FAILURE_FLAG=true
EVENT_LOG_CRITICAL_SEVERITIES=Critical,Fatal

# Retry / timeouts
MAX_RETRIES=3
RETRY_BACKOFF_MULTIPLIER=1.5
REDFISH_TIMEOUT_SECONDS=15

LOG_LEVEL=INFO
