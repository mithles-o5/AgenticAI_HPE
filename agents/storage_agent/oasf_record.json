{
  "name": "storage-agent",
  "version": "1.0.0",
  "schema_version": "0.7.0",
  "description": "Storage capacity monitoring, volume management, SAN/NAS/S3 health checks, anomaly detection, and GreenLake DSCC integration via pluggable adapters.",
  "skills": [
    {
      "name": "storage.monitoring.capacity"
    },
    {
      "name": "storage.monitoring.performance"
    },
    {
      "name": "storage.execute.volume_action"
    },
    {
      "name": "storage.discover.arrays"
    },
    {
      "name": "storage.diagnose.fault"
    },
    {
      "name": "storage.list.resources"
    }
  ],
  "domains": [
    "storage-infrastructure",
    "observability"
  ],
  "locators": [
    {
      "type": "openapi",
      "url": "http://storage-agent:8007/openapi.json"
    }
  ],
  "modules": {
    "protocols": [
      "dscc",
      "nas",
      "s3",
      "mock_storage"
